  "author": "Keygenix <support@keygenix.pro>",
  "license": "MIT",
  "homepage": "https://keygenix.pro",
  "repository": {
    "type": "git",
    "url": "https://github.com/wallet-io/keygenix-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/wallet-io/keygenix-mcp/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
